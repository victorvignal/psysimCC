# Copie este arquivo para .env e preencha os valores
OPENROUTER_API_KEY=sk-or-v1-...

# Modelo padrão — troque para testar outros
# Opções DeepSeek via OpenRouter:
#   deepseek/deepseek-chat        (DeepSeek V3 — recomendado)
#   deepseek/deepseek-r1          (raciocínio — mais lento)
#   deepseek/deepseek-r1-distill-qwen-32b
MODEL_ID=deepseek/deepseek-chat

# Modelo usado pelo gerador de fichas (pode ser diferente do simulador)
# Sugestões via OpenRouter:
#   anthropic/claude-sonnet-4-5   (melhor qualidade clínica)
#   openai/gpt-4o
#   google/gemini-pro-1.5
#   deepseek/deepseek-chat        (padrão, bom custo-benefício)
GENERATOR_MODEL_ID=deepseek/deepseek-chat

# Modelo do supervisor (recomendado: modelo mais capaz para análise clínica)
SUPERVISOR_MODEL_ID=deepseek/deepseek-chat

# Minimax TTS — usado com a flag --voice
MINIMAX_API_KEY=sk-cp-...
# MINIMAX_GROUP_ID=     (necessário apenas em contas antigas da Minimax)
# MINIMAX_VOICE_ID=     (padrão automático por gênero da ficha)
